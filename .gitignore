# Build trees
build/
build-*/

# Runtime artifacts (TensorRT engine caches, logs, pids)
var/

# TensorRT SDK is vendored by scripts/setup_tensorrt.sh, never committed
3rdparty/tensorrt-include/
3rdparty/tensorrt-libs/

# Model weights and exported graphs (large; regenerated by scripts)
resources/models/*
!resources/models/README.md
resources/onnx/*
!resources/onnx/README.md
*.engine

# Python tooling detritus
__pycache__/
*.pyc
.venv/
